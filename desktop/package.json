{
  "name": "auto-evo-ai-desktop",
  "version": "1.0.0",
  "description": "AUTO-EVO-AI Desktop Client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --config",
    "build:mac": "electron-builder --mac --config",
    "build:linux": "electron-builder --linux --config"
  },
  "build": {
    "appId": "com.autoevoai.desktop",
    "productName": "AUTO-EVO-AI",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["nsis"],
      "icon": "icon.png"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "icon.png"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.0.0"
  }
}
