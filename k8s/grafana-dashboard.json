{
  "apiVersion": 1,
  "panels": [
    {
      "title": "API 请求速率",
      "type": "graph",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 8},
      "targets": [{"expr": "rate(request_count_total[5m])", "legendFormat": "rpm"}]
    },
    {
      "title": "API 延迟",
      "type": "graph",
      "gridPos": {"x": 8, "y": 0, "w": 8, "h": 8},
      "targets": [{"expr": "request_latency_seconds_sum / request_latency_seconds_count", "legendFormat": "avg_latency"}]
    },
    {
      "title": "错误率",
      "type": "graph",
      "gridPos": {"x": 16, "y": 0, "w": 8, "h": 8},
      "targets": [{"expr": "rate(error_count_total[5m])", "legendFormat": "errors"}]
    },
    {
      "title": "模块健康状态",
      "type": "table",
      "gridPos": {"x": 0, "y": 8, "w": 24, "h": 8},
      "targets": [{"expr": "module_health_status", "legendFormat": ""}]
    },
    {
      "title": "系统资源 (CPU)",
      "type": "gauge",
      "gridPos": {"x": 0, "y": 16, "w": 8, "h": 8},
      "targets": [{"expr": "cpu_percent"}]
    },
    {
      "title": "系统资源 (内存)",
      "type": "gauge",
      "gridPos": {"x": 8, "y": 16, "w": 8, "h": 8},
      "targets": [{"expr": "memory_percent"}]
    },
    {
      "title": "活跃引擎",
      "type": "stat",
      "gridPos": {"x": 16, "y": 16, "w": 8, "h": 8},
      "targets": [{"expr": "engine_active{engine=~\"scheduler|events|queue\"}", "legendFormat": "{{engine}}"}]
    }
  ],
  "title": "AUTO-EVO-AI 监控面板",
  "tags": ["auto-evo-ai", "production"],
  "timezone": "browser"
}
