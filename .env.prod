# AUTO-EVO-AI V0.1 — 生产环境配置 (457模块)
# 用法: 复制为 .env 然后填写 API Keys
# cp .env.prod .env  (Linux/Mac)
# copy .env.prod .env (Windows)

# ═══════════ 必需: LLM API Keys (至少一个) ═══════════
# 注意：系统启动后模块将 lazyload 等待 API Key，无 Key 则全部模块待加载
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ZHIPU_API_KEY=

# ═══════════ 可选: 其他 LLM 提供商 ═══════════
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ═══════════ 可选: 通知渠道 Webhook URL ═══════════
FEISHU_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
WECHAT_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
GOOGLE_CHAT_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# ═══════════ 可选: 部署配置 ═══════════
EVO_HOSTNAME=0.0.0.0
EVO_FAST_START=false
GRAFANA_PASSWORD=admin123

# ═══════════ 可选: SMTP 邮件 ═══════════
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=

# ═══════════ 可选: 管理员 API Key ═══════════
# 留空由系统自动生成
EVO_ADMIN_KEY=
