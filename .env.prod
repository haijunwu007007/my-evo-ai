# AUTO-EVO-AI V0.1 — 生产环境配置 (457模块)
# 用法: 复制为 .env 然后填写 API Keys
# cp .env.prod .env && docker compose -f docker-compose.prod.yml up -d

# ═══════════ 必需: LLM API Keys (至少一个) ═══════════
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ZHIPU_API_KEY=

# ═══════════ 可选: 通知渠道 Webhook URL ═══════════
FEISHU_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
WECHAT_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
GOOGLE_CHAT_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# ═══════════ 可选: 部署配置 ═══════════
EVO_HOSTNAME=localhost
GRAFANA_PASSWORD=admin123

# ═══════════ 可选: SMTP 邮件 ═══════════
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
