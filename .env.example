# AUTO-EVO-AI V0.1 — 环境变量模板 (535模块)
# 复制此文件为 .env 并填充实际值

# === AI 模型配置 ===
# 智谱 AI (GLM系列)
ZHIPU_API_KEY=your_zhipu_api_key_here

# OpenAI (可选)
OPENAI_API_KEY=your_openai_api_key_here

# 自定义 AI (可选)
AI_CUSTOM_API_KEY=your_custom_api_key_here
AI_CUSTOM_BASE_URL=
AI_CUSTOM_MODEL=

# 默认模型 (默认: gpt-4o)
AI_DEFAULT_MODEL=gpt-4o

# === 数据库配置 ===
DB_TYPE=sqlite
# MySQL (可选)
DB_MYSQL_HOST=127.0.0.1
DB_MYSQL_PORT=3306
DB_MYSQL_USER=
DB_MYSQL_PASSWORD=
DB_MYSQL_DATABASE=auto_evo_ai
# PostgreSQL (可选)
DB_PG_HOST=127.0.0.1
DB_PG_PORT=5432
DB_PG_USER=
DB_PG_PASSWORD=
DB_PG_DATABASE=auto_evo_ai

# === 通讯渠道配置 ===
# 飞书
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 钉钉
DINGTALK_ACCESS_TOKEN=
DINGTALK_SECRET=
# 企业微信
WECOM_CORP_ID=
WECOM_CORP_SECRET=
WECOM_AGENT_ID=
# Telegram
TELEGRAM_BOT_TOKEN=
# Slack
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# === SMTP 邮件 ===
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=AUTO-EVO-AI

# === 系统配置 ===
LOG_LEVEL=INFO
