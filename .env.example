# ============================================================
# AUTO-EVO-AI V0.1 — 环境变量配置
# ============================================================
# 复制此文件为 .env 后按需修改
# cp .env.example .env

# --- 核心配置 ---
EVO_ENV=development
EVO_DEBUG=true
EVO_LOG_JSON=false
EVO_DATA_DIR=./.evo_data

# --- 智谱 AI ---
# ZHIPU_API_KEY=your_key_here

# --- OpenAI ---
# OPENAI_API_KEY=your_key_here
# OPENAI_API_BASE=https://api.openai.com/v1

# --- API2D 中转（兼容 OpenAI） ---
# API2D_API_KEY=your_key_here

# --- 通知推送 ---
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
# DINGTALK_SECRET=your_secret_here

# --- 外部工具 Key ---
# ONE_API_BASE=http://localhost:3000
# ONE_API_KEY=your_key_here
# LITELLM_API_KEY=your_key_here
# MEILI_MASTER_KEY=your_key_here
# LANGFUSE_PUBLIC_KEY=your_key_here
# LANGFUSE_SECRET_KEY=your_key_here
# TABBY_API_KEY=your_key_here
# FIRECRAWL_API_KEY=your_key_here
# OPENCLAW_API_KEY=your_key_here

# --- Grafana / Prometheus ---
# PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus
# GRAFANA_ADMIN_PASSWORD=admin

# --- MinIO (S3 兼容) ---
# MINIO_ROOT_USER=admin
# MINIO_ROOT_PASSWORD=minio123

# --- Web 服务 ---
# PORT=8765
# HOST=127.0.0.1

# --- Ntfy (推送通知) ---
# NTFY_TOPIC=evo-alerts
# NTFY_SERVER=https://ntfy.sh
