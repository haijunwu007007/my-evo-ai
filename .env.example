# AUTO-EVO-AI V0.1 — 环境变量配置模板
# 复制此文件为 .env 并填入实际值
#
# cp .env.example .env   (Linux/macOS)
# copy .env.example .env  (Windows)
#
# 使用方式: 系统启动时自动从环境变量读取配置
# 优先级: 环境变量 > config.yaml > 默认值
#
# ═══════════════════════════════════════════════════════
# CICD / GitHub / GitLab
# ═══════════════════════════════════════════════════════
# GitHub API访问令牌 (repo/workflow权限)
GITHUB_TOKEN=
# GitHub用户名
GITHUB_USERNAME=
# 默认操作的仓库 owner/repo
GITHUB_DEFAULT_REPO=
# GitLab API访问令牌
GITLAB_TOKEN=
# Docker Hub访问令牌
DOCKER_HUB_TOKEN=
# Docker Hub登录用户名
DOCKER_HUB_USER=

# ═══════════════════════════════════════════════════════
# 数据库
# ═══════════════════════════════════════════════════════
# MongoDB连接字符串
MONGO_URL=
# PostgreSQL连接字符串（可选，默认使用SQLite）
DATABASE_URL=
# Redis连接地址（可选，默认使用内存缓存）
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════════════════
# LLM / AI (各厂商选其一)
# ═══════════════════════════════════════════════════════
# OpenAI GPT系列
OPENAI_API_KEY=
# OpenAI接口地址(可改为代理)
OPENAI_BASE_URL=https://api.openai.com/v1
# 默认使用的GPT模型
OPENAI_DEFAULT_MODEL=gpt-4o
# LLM单次请求最大token数
LLM_MAX_TOKENS=4096
# LLM生成温度(0-2)
LLM_TEMPERATURE=0.7
# LLM请求超时时间(秒)
LLM_TIMEOUT=60

# Anthropic Claude系列
ANTHROPIC_API_KEY=
# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# Google Gemini
GEMINI_API_KEY=
# 智谱GLM系列
ZHIPU_API_KEY=
# 本地Ollama服务
OLLAMA_BASE_URL=http://localhost:11434

# ═══════════════════════════════════════════════════════
# 通知推送 (各渠道选其一)
# ═══════════════════════════════════════════════════════
# 钉钉机器人Webhook URL + Secret（逗号分隔）
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=
# 企业微信机器人
WECHAT_WEBHOOK_URL=
# 飞书机器人
FEISHU_WEBHOOK_URL=
# PushPlus推送
PUSHPLUS_TOKEN=
# Server酱
SERVERCHAN_KEY=
# iOS Bark推送
BARK_DEVICE_KEY=
BARK_SERVER=https://api.day.app
# 邮件SMTP
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=

# ═══════════════════════════════════════════════════════
# 服务器配置
# ═══════════════════════════════════════════════════════
# API服务端口（默认8765）
EVO_PORT=8765
# API服务地址（默认127.0.0.1）
EVO_HOST=127.0.0.1
# 是否启用JWT+API Key认证
EVO_AUTH_ENABLED=false
